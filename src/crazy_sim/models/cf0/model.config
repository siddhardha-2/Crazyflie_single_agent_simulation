<?xml version="1.0"?>
<model>
  <name>crazyflie_bmo</name>
  <version>1.0</version>
  <sdf version="1.8">model.sdf</sdf>
  <author>
    <name>Siddhardha (based on Bitcraze Crazyflie model)</name>
  </author>
  <description>
    Modified Crazyflie 2.X model for BMO multi-drone simulation.
    Identical to Bitcraze original EXCEPT: robotNamespace removed from all
    plugins so that each instance gets unique namespaced topics from its
    model name (set via the name tag in include).
  </description>
</model>