<?xml version="1.0" ?>
<!--
  Crazyflie BMO Model — Modified for multi-drone simulation

  This is a copy of the Bitcraze Crazyflie 2.X Gazebo model with ONE change:
  <robotNamespace> is REMOVED from all motor and velocity control plugins.

  Why: The original model hardcodes <robotNamespace>crazyflie</robotNamespace>,
  which means ALL instances share the same Gazebo topics. By removing it,
  gz-sim uses the model's scoped name (set by <name> in <include>) as the
  namespace. So <name>cf0</name> gets topics like /cf0/gazebo/command/twist.

  Mesh files are referenced from the Bitcraze crazyflie-simulation repo via
  GZ_SIM_RESOURCE_PATH. Make sure both our models dir and the Bitcraze gazebo
  dir are on that path.

  Original source: github.com/bitcraze/crazyflie-simulation (MIT License)
  Original author: Kimberly McGuire (Bitcraze AB)
-->
<sdf version="1.8">
  <model name="crazyflie_bmo">

    <!-- ================================================================= -->
    <!-- Body link: main chassis with inertia, collision box, visual mesh  -->
    <!-- ================================================================= -->
    <link name="body">
      <pose>0 0 17.425E-3 0 0 0</pose>
      <inertial>
        <mass>0.025</mass>
        <inertia>
          <ixx>16.571710E-06</ixx>
          <iyy>16.655602E-06</iyy>
          <izz>29.261652E-06</izz>
          <ixy>0.830806E-06</ixy>
          <ixz>0.718277E-06</ixz>
          <iyz>1.800197E-06</iyz>
        </inertia>
      </inertial>
      <collision name="body_collision">
        <geometry>
          <box>
            <size>0.10 0.10 34.850E-3</size>
          </box>
        </geometry>
      </collision>
      <visual name="body_visual">
        <geometry>
          <mesh>
            <uri>meshes/cf2_assembly.dae</uri>
          </mesh>
        </geometry>
      </visual>

      <!-- IMU Sensor -->
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>100</update_rate>
        <visualize>true</visualize>
        <topic>/model/cf0/imu</topic>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>

    <!-- ================================================================= -->
    <!-- Propeller links: 4 props with inertia and visual mesh             -->
    <!-- m1 (front-right, CCW), m2 (rear-right, CW),                      -->
    <!-- m3 (rear-left, CCW),   m4 (front-left, CW)                       -->
    <!-- ================================================================= -->
    <link name="m1_prop">
      <pose>0.031 -0.031 0.021 0 0 0</pose>
      <inertial>
        <mass>0.0008</mass>
        <inertia>
          <ixx>8.33333E-09</ixx>
          <iyy>1.08333E-07</iyy>
          <izz>1.13333E-07</izz>
        </inertia>
      </inertial>
      <visual name="m1_visual">
        <geometry>
          <mesh>
            <uri>meshes/ccw_prop.dae</uri>
          </mesh>
        </geometry>
      </visual>
    </link>

    <link name="m2_prop">
      <pose>-0.031 -0.031 0.021 0 0 0</pose>
      <inertial>
        <mass>0.0008</mass>
        <inertia>
          <ixx>8.33333E-09</ixx>
          <iyy>1.08333E-07</iyy>
          <izz>1.13333E-07</izz>
        </inertia>
      </inertial>
      <visual name="m2_visual">
        <geometry>
          <mesh>
            <uri>meshes/cw_prop.dae</uri>
          </mesh>
        </geometry>
      </visual>
    </link>

    <link name="m3_prop">
      <pose>-0.031 0.031 0.021 0 0 0</pose>
      <inertial>
        <mass>0.0008</mass>
        <inertia>
          <ixx>8.33333E-09</ixx>
          <iyy>1.08333E-07</iyy>
          <izz>1.13333E-07</izz>
        </inertia>
      </inertial>
      <visual name="m3_visual">
        <geometry>
          <mesh>
            <uri>meshes/ccw_prop.dae</uri>
          </mesh>
        </geometry>
      </visual>
    </link>

    <link name="m4_prop">
      <pose>0.031 0.031 0.021 0 0 0</pose>
      <inertial>
        <mass>0.0008</mass>
        <inertia>
          <ixx>8.33333E-09</ixx>
          <iyy>1.08333E-07</iyy>
          <izz>1.13333E-07</izz>
        </inertia>
      </inertial>
      <visual name="m4_visual">
        <geometry>
          <mesh>
            <uri>meshes/cw_prop.dae</uri>
          </mesh>
        </geometry>
      </visual>
    </link>

    <!-- ================================================================= -->
    <!-- Joints: connect each propeller to the body                        -->
    <!-- ================================================================= -->
    <joint name="m1_joint" type="revolute">
      <child>m1_prop</child>
      <parent>body</parent>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>
    <joint name="m2_joint" type="revolute">
      <child>m2_prop</child>
      <parent>body</parent>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>
    <joint name="m3_joint" type="revolute">
      <child>m3_prop</child>
      <parent>body</parent>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>
    <joint name="m4_joint" type="revolute">
      <child>m4_prop</child>
      <parent>body</parent>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>

    <!-- ================================================================= -->
    <!-- Motor plugins: 4x MulticopterMotorModel                          -->
    <!-- NOTE: <robotNamespace> is intentionally REMOVED.                  -->
    <!-- gz-sim will use the model's scoped name as namespace.             -->
    <!-- ================================================================= -->
    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>m1_joint</jointName>
      <linkName>m1_prop</linkName>
      <turningDirection>ccw</turningDirection>
      <maxRotVelocity>2618</maxRotVelocity>
      <motorConstant>1.28192e-08</motorConstant>
      <momentConstant>0.005964552</momentConstant>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>0.0000001</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>20</rotorVelocitySlowdownSim>
      <actuator_number>0</actuator_number>
      <motorType>velocity</motorType>
    </plugin>

    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>m2_joint</jointName>
      <linkName>m2_prop</linkName>
      <turningDirection>cw</turningDirection>
      <maxRotVelocity>2618</maxRotVelocity>
      <motorConstant>1.28192e-08</motorConstant>
      <momentConstant>0.005964552</momentConstant>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>0.0000001</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>20</rotorVelocitySlowdownSim>
      <actuator_number>1</actuator_number>
      <motorType>velocity</motorType>
    </plugin>

    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>m3_joint</jointName>
      <linkName>m3_prop</linkName>
      <turningDirection>ccw</turningDirection>
      <maxRotVelocity>2618</maxRotVelocity>
      <motorConstant>1.28192e-08</motorConstant>
      <momentConstant>0.005964552</momentConstant>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>0.0000001</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>20</rotorVelocitySlowdownSim>
      <actuator_number>2</actuator_number>
      <motorType>velocity</motorType>
    </plugin>

    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>m4_joint</jointName>
      <linkName>m4_prop</linkName>
      <turningDirection>cw</turningDirection>
      <maxRotVelocity>2618</maxRotVelocity>
      <motorConstant>1.28192e-08</motorConstant>
      <momentConstant>0.005964552</momentConstant>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>0.0000001</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>20</rotorVelocitySlowdownSim>
      <actuator_number>3</actuator_number>
      <motorType>velocity</motorType>
    </plugin>

    <!-- ================================================================= -->
    <!-- Velocity controller: accepts Twist commands, controls attitude     -->
    <!-- NOTE: <robotNamespace> is intentionally REMOVED.                  -->
    <!-- commandSubTopic is relative to the model's scoped namespace.      -->
    <!-- ================================================================= -->
    <plugin filename="gz-sim-multicopter-control-system"
            name="gz::sim::systems::MulticopterVelocityControl">

        <robotNamespace>cf0</robotNamespace>
      <commandSubTopic>gazebo/command/twist</commandSubTopic>
      <enableSubTopic>enable</enableSubTopic>
      <comLinkName>body</comLinkName>
      <velocityGain>1.25 1.25 0.2425</velocityGain>
      <attitudeGain>0.02 0.02 0.02</attitudeGain>
      <angularRateGain>0.005 0.005 0.005</angularRateGain>
      <rotorConfiguration>
        <rotor>
          <jointName>m1_joint</jointName>
          <forceConstant>1.28192e-08</forceConstant>
          <momentConstant>0.005964552</momentConstant>
          <direction>1</direction>
        </rotor>
        <rotor>
          <jointName>m2_joint</jointName>
          <forceConstant>1.28192e-08</forceConstant>
          <momentConstant>0.005964552</momentConstant>
          <direction>-1</direction>
        </rotor>
        <rotor>
          <jointName>m3_joint</jointName>
          <forceConstant>1.28192e-08</forceConstant>
          <momentConstant>0.005964552</momentConstant>
          <direction>1</direction>
        </rotor>
        <rotor>
          <jointName>m4_joint</jointName>
          <forceConstant>1.28192e-08</forceConstant>
          <momentConstant>0.005964552</momentConstant>
          <direction>-1</direction>
        </rotor>
      </rotorConfiguration>
    </plugin>
   

    <!-- ================================================================= -->
    <!-- Odometry publisher: publishes pose and velocity                   -->
    <!-- Topic: /model/{model_name}/odometry                               -->
    <!-- ================================================================= -->
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <dimensions>3</dimensions>
    </plugin>

     <plugin filename="gz-sim-imu-system"
        name="gz::sim::systems::Imu">
    </plugin>

  </model>
</sdf>